# --- CROO Agent Protocol (CAP) ---
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws
CROO_SDK_KEY=croo_sk_xxx
BASE_RPC_URL=https://mainnet.base.org

# --- LLM (GLM-5.2 via Ollama Cloud, OpenAI-compatible) ---
OLLAMA_API_KEY=
OLLAMA_BASE_URL=https://ollama.com/v1

# --- Target specialist service IDs (filled in Phase-0 Task 5) ---
SVC_RESEARCH=
SVC_LANDING=
SVC_IMAGE=
SVC_SEO=

# --- Praeco agent identity (Phase-0 Task 5) ---
PRAECO_AGENT_ID=ce5362ad-272f-42aa-b656-f4e51796bcaf
PRAECO_AGENT_WALLET=0xee47A5bda206E188a2857F908E5E2E62C7DA7D31

# --- Engine budget (optional; defaults shown) ---
RUN_BUDGET_USDC=2.00
LEG_CAP_USDC=0.60
# USDC_TOKEN_ADDRESS= # defaults to Base mainnet USDC

# --- Web layer (Phase 2 — Door A) ---
RUNS_DIR=/data/runs   # Railway volume mount; persisted RunRecord replays live here (defaults to ./runs locally)
# NODE_ENV=production   # Railway sets this in prod; leave UNSET locally (Next dev needs development mode)
# PUBLIC_BASE_URL=https://<your-railway-domain>   # optional, absolute share links
# LIVE_RUN_TOKEN=   # DEFERRED — set ONLY to enable RECTOR-gated on-chain runs (Authorization: Bearer <token>); UNSET = live disabled / fail-closed
#                     Sandbox+replay need neither LIVE_RUN_TOKEN nor SVC_* (sandbox clears pins).
